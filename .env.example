# Database
DATABASE_URL="postgresql://user:password@localhost:5432/wazenly"

# Redis
REDIS_URL="redis://localhost:6379"

# NextAuth
NEXTAUTH_SECRET="your-nextauth-secret-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Meta / WhatsApp Cloud API
META_APP_ID="your-meta-app-id"
META_APP_SECRET="your-meta-app-secret"

# Encryption (AES-256 — must be exactly 32 chars)
ENCRYPTION_KEY="your-32-char-encryption-key-here"

# Webhook
WEBHOOK_BASE_URL="https://your-public-domain.com"
# Single verify token for all WhatsApp numbers — generate with:
# node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
WHATSAPP_WEBHOOK_VERIFY_TOKEN="your-random-token-here"

# SMTP (required — verification, password reset emails)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="your-email@gmail.com"

# Email verification
EMAIL_VERIFICATION_TTL_HOURS="24"
REQUIRE_EMAIL_VERIFICATION="true"

# Internal service-to-service auth (web -> api, e.g. OAuth signup) — same value in both apps
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_SERVICE_SECRET="your-random-internal-secret-min-32-chars"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Browser-facing API base — with a single-domain/path-based nginx setup this is
# usually "<NEXT_PUBLIC_APP_URL>/api" (same origin as the web app).
NEXT_PUBLIC_API_URL="http://localhost:4000/api"
# Internal server-side URL of the API (used by Next.js server-side code) —
# stays localhost even in production since it's not routed through nginx/Cloudflare.
API_URL="http://localhost:4000"
# Allowed browser origin(s) for the API's CORS + Socket.IO — comma-separated
# if you need more than one (e.g. apex + www).
CORS_ORIGIN="http://localhost:3000"
PORT="4000"
NODE_ENV="development"
