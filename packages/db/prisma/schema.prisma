// Wazenly — WhatsApp BSP SaaS Platform
// Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────
// AUTH & MULTI-TENANCY
// ─────────────────────────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  emailVerified     DateTime?
  password          String?
  name              String?
  image             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  workspaceMembers  WorkspaceMember[]
  assignedConvos    Conversation[]    @relation("AssignedConversations")
  notes             ConversationNote[]
  sentInvitations   Invitation[]
  notifications     Notification[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  email     String
  tokenHash String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────────────────
// WORKSPACE & TEAM
// ─────────────────────────────────────────────────────────

model Workspace {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  logo         String?
  timezone     String   @default("UTC")
  defaultLang  String   @default("en")
  planId       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  members       WorkspaceMember[]
  apiKeys       ApiKey[]
  numbers       WhatsAppNumber[]
  templates     Template[]
  contacts      Contact[]
  contactLists  ContactList[]
  campaigns     Campaign[]
  conversations Conversation[]
  flows         Flow[]
  webhooks      WebhookEndpoint[]
  invitations   Invitation[]
  subscription  Subscription?
  plan          BillingPlan?     @relation(fields: [planId], references: [id])
}

enum MemberRole {
  OWNER
  ADMIN
  MANAGER
  AGENT
  VIEWER
}

model WorkspaceMember {
  id          String     @id @default(cuid())
  workspaceId String
  userId      String
  role        MemberRole @default(AGENT)
  invitedAt   DateTime   @default(now())
  joinedAt    DateTime?
  inviteToken String?    @unique

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

model Invitation {
  id              String     @id @default(cuid())
  workspaceId     String
  email           String
  role            MemberRole
  tokenHash       String     @unique
  invitedByUserId String
  expires         DateTime
  acceptedAt      DateTime?
  createdAt       DateTime   @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy User      @relation(fields: [invitedByUserId], references: [id])

  @@index([workspaceId])
  @@unique([workspaceId, email])
}

model ApiKey {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  keyHash     String    @unique
  keyPrefix   String
  lastUsedAt  DateTime?
  requestCount Int      @default(0)
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────
// WHATSAPP NUMBERS
// ─────────────────────────────────────────────────────────

enum NumberStatus {
  CONNECTED
  DISCONNECTED
  PENDING
}

enum NumberTier {
  TIER_1
  TIER_2
  TIER_3
  TIER_4
}

model WhatsAppNumber {
  id                  String       @id @default(cuid())
  workspaceId         String       @unique
  displayName         String
  phoneNumber         String
  phoneNumberId       String       @unique
  wabaId              String
  accessToken         String       @db.Text
  metaAppId           String?
  webhookVerifyToken  String
  status              NumberStatus @default(PENDING)
  tier                NumberTier   @default(TIER_1)
  dailyLimit          Int          @default(1000)
  monthlyLimit        Int          @default(30000)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  templates     Template[]
  campaigns     Campaign[]
  conversations Conversation[]
  messages      Message[]
  flows         Flow[]
  contacts      Contact[]
  contactLists  ContactList[]

  @@index([workspaceId])
}

// ─────────────────────────────────────────────────────────
// TEMPLATES
// ─────────────────────────────────────────────────────────

enum TemplateStatus {
  APPROVED
  PENDING
  REJECTED
  PAUSED
}

enum TemplateCategory {
  MARKETING
  UTILITY
  AUTHENTICATION
}

enum TemplateHeaderType {
  NONE
  TEXT
  IMAGE
  VIDEO
  DOCUMENT
  LOCATION
}

model Template {
  id           String            @id @default(cuid())
  workspaceId  String
  numberId     String?
  metaId       String?
  name         String
  category     TemplateCategory
  language     String            @default("en")
  status       TemplateStatus    @default(PENDING)
  headerType   TemplateHeaderType @default(NONE)
  headerText   String?
  headerUrl    String?
  headerHandle String?
  body         String            @db.Text
  footer       String?
  buttons      Json?
  variables    Json?
  lastSyncedAt DateTime?
  lastUsedAt   DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  workspace      Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  number         WhatsAppNumber?  @relation(fields: [numberId], references: [id])
  campaigns      Campaign[]
  components     TemplateComponent[]

  @@index([workspaceId])
  @@index([status])
}

model TemplateComponent {
  id         String   @id @default(cuid())
  templateId String
  type       String
  format     String?
  text       String?  @db.Text
  buttons    Json?
  example    Json?

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────
// CONTACTS
// ─────────────────────────────────────────────────────────

enum ContactStatus {
  ACTIVE
  UNSUBSCRIBED
  BLACKLISTED
  INVALID
  DORMANT
  FAILED_DELIVERY
}

enum ReplyIntent {
  UNKNOWN
  INTERESTED
  NOT_INTERESTED
}

model Contact {
  id                  String        @id @default(cuid())
  workspaceId         String
  numberId            String
  name                String
  phone               String
  email               String?
  tags                String[]
  customFields        Json?
  optedOut            Boolean       @default(false)
  optedOutAt          DateTime?
  status              ContactStatus @default(ACTIVE)
  statusReason        String?
  statusChangedAt     DateTime?
  statusChangedBy     String?
  engagementScore     Int           @default(50)
  consecutiveFailures Int           @default(0)
  lastMessaged        DateTime?
  replyIntent         ReplyIntent   @default(UNKNOWN)
  replyIntentAt       DateTime?
  replyIntentSample   String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  workspace        Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  number           WhatsAppNumber      @relation(fields: [numberId], references: [id])
  listMemberships  ContactListMember[]
  campaignContacts CampaignContact[]
  conversations    Conversation[]
  messages         Message[]
  flowSessions     FlowSession[]

  @@unique([workspaceId, numberId, phone])
  @@index([workspaceId])
  @@index([numberId])
  @@index([phone])
  @@index([status])
  @@index([replyIntent])
}

model ContactList {
  id          String   @id @default(cuid())
  workspaceId String
  numberId    String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  number    WhatsAppNumber      @relation(fields: [numberId], references: [id])
  members   ContactListMember[]
  campaigns Campaign[]          @relation("CampaignContactLists")

  @@index([workspaceId])
  @@index([numberId])
}

model ContactListMember {
  id        String   @id @default(cuid())
  listId    String
  contactId String
  addedAt   DateTime @default(now())

  list    ContactList @relation(fields: [listId], references: [id], onDelete: Cascade)
  contact Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([listId, contactId])
}

// ─────────────────────────────────────────────────────────
// CAMPAIGNS
// ─────────────────────────────────────────────────────────

enum CampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  PAUSED
  COMPLETED
  FAILED
}

enum CampaignType {
  ONE_TIME
  RECURRING
}

enum CampaignFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

model Campaign {
  id                 String            @id @default(cuid())
  workspaceId        String
  name               String
  description        String?
  numberId           String
  templateId         String?
  status             CampaignStatus    @default(DRAFT)
  type               CampaignType      @default(ONE_TIME)
  frequency          CampaignFrequency?
  scheduledAt        DateTime?
  endDate            DateTime?
  timezone           String            @default("UTC")
  rateLimit          Int               @default(60)
  throttleHours      Int?
  quietHoursStart    String?
  quietHoursEnd      String?
  totalRecipients    Int               @default(0)
  sentCount          Int               @default(0)
  deliveredCount     Int               @default(0)
  readCount          Int               @default(0)
  failedCount        Int               @default(0)
  variableMapping    Json?
  bullJobId          String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  workspace    Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  number       WhatsAppNumber    @relation(fields: [numberId], references: [id])
  template     Template?         @relation(fields: [templateId], references: [id])
  contacts     CampaignContact[]
  contactLists ContactList[]     @relation("CampaignContactLists")

  @@index([workspaceId])
  @@index([status])
}

enum ContactMessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

model CampaignContact {
  id           String               @id @default(cuid())
  campaignId   String
  contactId    String?
  phone        String
  variables    Json?
  status       ContactMessageStatus @default(QUEUED)
  messageId    String?
  sentAt       DateTime?
  deliveredAt  DateTime?
  readAt       DateTime?
  failedAt     DateTime?
  errorMessage String?
  createdAt    DateTime             @default(now())

  campaign Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact  Contact?  @relation(fields: [contactId], references: [id])

  @@index([campaignId])
  @@index([status])
}

// ─────────────────────────────────────────────────────────
// CONVERSATIONS & MESSAGES (INBOX)
// ─────────────────────────────────────────────────────────

enum ConversationStatus {
  OPEN
  RESOLVED
  BOT
}

model Conversation {
  id               String             @id @default(cuid())
  workspaceId      String
  numberId         String
  contactId        String?
  phone            String
  contactName      String?
  status           ConversationStatus @default(OPEN)
  assignedUserId   String?
  lastMessageAt    DateTime?
  unreadCount      Int                @default(0)
  isOptedOut       Boolean            @default(false)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  workspace    Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  number       WhatsAppNumber @relation(fields: [numberId], references: [id])
  contact      Contact?       @relation(fields: [contactId], references: [id])
  assignedUser User?          @relation("AssignedConversations", fields: [assignedUserId], references: [id])
  messages     Message[]
  notes        ConversationNote[]

  @@unique([workspaceId, numberId, phone])
  @@index([workspaceId])
  @@index([status])
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  LOCATION
  CONTACTS
  TEMPLATE
  INTERACTIVE
  STICKER
  REACTION
  BUTTON
  UNKNOWN
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

model Message {
  id             String           @id @default(cuid())
  workspaceId    String?
  conversationId String?
  numberId       String
  contactId      String?
  phone          String
  direction      MessageDirection
  type           MessageType      @default(TEXT)
  status         MessageStatus    @default(QUEUED)
  metaMessageId  String?          @unique
  body           String?          @db.Text
  mediaUrl       String?
  mediaCaption   String?
  mediaFilename  String?
  templateName   String?
  templateVars   Json?
  replyToId      String?
  reaction       String?
  location       Json?
  timestamp      DateTime         @default(now())
  sentAt         DateTime?
  deliveredAt    DateTime?
  readAt         DateTime?
  failedAt       DateTime?
  errorCode      String?
  errorMessage   String?
  raw            Json?

  number       WhatsAppNumber @relation(fields: [numberId], references: [id])
  contact      Contact?       @relation(fields: [contactId], references: [id])
  conversation Conversation?  @relation(fields: [conversationId], references: [id])
  replyTo      Message?       @relation("MessageReplies", fields: [replyToId], references: [id])
  replies      Message[]      @relation("MessageReplies")

  @@index([conversationId])
  @@index([phone])
  @@index([metaMessageId])
}

model ConversationNote {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  body           String   @db.Text
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])
}

model QuickReply {
  id          String @id @default(cuid())
  workspaceId String
  title       String
  body        String @db.Text

  @@index([workspaceId])
}

// ─────────────────────────────────────────────────────────
// CHATBOT FLOWS
// ─────────────────────────────────────────────────────────

enum FlowStatus {
  ACTIVE
  INACTIVE
  DRAFT
}

model Flow {
  id          String     @id @default(cuid())
  workspaceId String
  numberId    String?
  name        String
  description String?
  status      FlowStatus @default(DRAFT)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  number    WhatsAppNumber? @relation(fields: [numberId], references: [id])
  nodes     FlowNode[]
  edges     FlowEdge[]
  triggers  FlowTrigger[]
  sessions  FlowSession[]
}

model FlowNode {
  id       String  @id @default(cuid())
  flowId   String
  type     String
  label    String
  positionX Float  @default(0)
  positionY Float  @default(0)
  data     Json

  flow     Flow       @relation(fields: [flowId], references: [id], onDelete: Cascade)
  outEdges FlowEdge[] @relation("SourceNode")
  inEdges  FlowEdge[] @relation("TargetNode")
}

model FlowEdge {
  id           String  @id @default(cuid())
  flowId       String
  sourceNodeId String
  targetNodeId String
  label        String?
  condition    Json?

  flow       Flow     @relation(fields: [flowId], references: [id], onDelete: Cascade)
  sourceNode FlowNode @relation("SourceNode", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode FlowNode @relation("TargetNode", fields: [targetNodeId], references: [id], onDelete: Cascade)
}

enum FlowTriggerType {
  KEYWORD
  ANY_MESSAGE
  OPT_IN
  CAMPAIGN_REPLY
}

enum FlowSessionState {
  WAITING_INPUT
  WAITING_DELAY
}

model FlowSession {
  id          String           @id @default(cuid())
  workspaceId String
  flowId      String
  contactId   String
  numberId    String
  nodeId      String
  state       FlowSessionState
  variables   Json             @default("{}")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  flow    Flow    @relation(fields: [flowId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([contactId, numberId])
}

model FlowTrigger {
  id       String          @id @default(cuid())
  flowId   String
  type     FlowTriggerType
  keywords String[]
  isActive Boolean         @default(true)

  flow Flow @relation(fields: [flowId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────
// WEBHOOKS
// ─────────────────────────────────────────────────────────

model WebhookEndpoint {
  id          String   @id @default(cuid())
  workspaceId String
  url         String
  events      String[]
  secret      String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  events_   WebhookEvent[]
}

model WebhookEvent {
  id         String   @id @default(cuid())
  endpointId String
  event      String
  payload    Json
  status     String   @default("pending")
  attempts   Int      @default(0)
  sentAt     DateTime?
  error      String?
  createdAt  DateTime @default(now())

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────────────────

enum NotificationType {
  INVITATION_ACCEPTED
  TEAM_MEMBER_JOINED
  CAMPAIGN_COMPLETED
  TEMPLATE_APPROVED
  WEBHOOK_FAILED
  QUEUE_JOB_FAILED
  NEW_MESSAGE
}

model Notification {
  id          String           @id @default(cuid())
  workspaceId String
  userId      String
  type        NotificationType
  title       String
  message     String
  link        String?
  readAt      DateTime?
  createdAt   DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([workspaceId])
}

// ─────────────────────────────────────────────────────────
// DIAGNOSTICS
// ─────────────────────────────────────────────────────────

model EmailLog {
  id        String   @id @default(cuid())
  to        String
  subject   String
  status    String
  error     String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────
// BILLING
// ─────────────────────────────────────────────────────────

model BillingPlan {
  id             String  @id @default(cuid())
  name           String  @unique
  priceMonthly   Float
  pricePerMessage Float  @default(0)
  messageLimit   Int
  numberLimit    Int
  memberLimit    Int
  features       Json

  workspaces    Workspace[]
  subscriptions Subscription[]
}

model Subscription {
  id          String    @id @default(cuid())
  workspaceId String    @unique
  planId      String
  status      String    @default("active")
  startedAt   DateTime  @default(now())
  expiresAt   DateTime?
  cancelledAt DateTime?

  workspace Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  plan      BillingPlan @relation(fields: [planId], references: [id])
}

// ─────────────────────────────────────────────────────────
// ANALYTICS (pre-aggregated)
// ─────────────────────────────────────────────────────────

model DailyAnalytics {
  id             String   @id @default(cuid())
  workspaceId    String
  numberId       String?
  date           DateTime @db.Date
  messagesSent   Int      @default(0)
  delivered      Int      @default(0)
  read           Int      @default(0)
  failed         Int      @default(0)
  inbound        Int      @default(0)
  newContacts    Int      @default(0)

  @@unique([workspaceId, numberId, date])
  @@index([workspaceId, date])
}

// ─────────────────────────────────────────────────────────
// PUBLIC MARKETING SITE
// ─────────────────────────────────────────────────────────

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  company   String?
  email     String
  phone     String?
  subject   String
  message   String
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}
